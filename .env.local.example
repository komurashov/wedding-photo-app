# ---- Cloudinary (хранилище фото) ----
# Берётся из Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Папка в Cloudinary, куда складывать фото
CLOUDINARY_UPLOAD_FOLDER=wedding

# Эти две — публичные (нужны браузеру для прямой загрузки). НЕ секрет.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key

# ---- Supabase (счётчик + проверка лимита) ----
# Project Settings -> API
SUPABASE_URL=https://xxxxxxxx.supabase.co
# ВАЖНО: service_role key (секретный, только сервер). НЕ anon key.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ---- Админ-страница /admin ----
# Пароль для входа в админку (просмотр всех фото + скачать всё одним архивом).
# Придумайте свой. Если пусто — админка закрыта.
ADMIN_PASSWORD=придумайте_пароль

# ---- Настройки приложения ----
# Лимит фото на одного гостя (устройство)
NEXT_PUBLIC_MAX_PHOTOS=10
# Заголовок на странице
NEXT_PUBLIC_EVENT_TITLE=Наша свадьба
NEXT_PUBLIC_EVENT_SUBTITLE=Поделитесь своими фото с нами 💛
